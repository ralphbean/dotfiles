[user]
	name = Ralph Bean
	email = rbean@redhat.com
    signingkey = 2B47F5B121A5CB46C9F07DC8EDFB33D41A69F819
[color]
    ui = auto
[branch]
    autosetuprebase = always
[alias]
    hist = log --graph --date=relative --abbrev-commit --pretty=format:\"           \t%C(yellow)%h %C(red)%ad %C(cyan)%aN%C(reset)   \t| %s%C(blue)%d%C(reset)\"
    l = "!source ~/.githelpers && pretty_git_log"
    amend = commit --amend
    aa = add --all
    head = !git l -1
    h = !git head
    hp = "!source ~/.githelpers && show_git_head"
    r = !git l
    ra = !git r --all
    ff = merge --ff-only
    pullff = pull --ff-only
    noff = merge --no-ff
    la = !git l --all
    div = divergence
    gn = goodness
    gnc = goodness --cached
    fa = fetch --all
    pa = push --all
    b = branch
    ds = diff --stat=160,120
    dh1 = diff HEAD~1
	cdr = "!__(){ ( set -x; ssh -p 29418 code.engineering.redhat.com gerrit set-reviewers \"$@\" -a avicenzi -a danrodri -a esharifu -a jazhang -a jluza -a mtahir -a ngillett -a rajkumar -a rbikar -a rmcgover -a tchandwa ; ); }; __"
    cherry-pick-on = "!__(){ ON=\"$1\"; PICK=\"$2\"; ( set -o pipefail; export GIT_INDEX_FILE=\"$(git rev-parse --git-dir)/cherry-pick-on-index\"; git read-tree \"$ON\" && git show \"$PICK\" | git apply --cached && git log -1 --format=format:%B \"$PICK\" | git commit-tree -p \"$ON\" $(git write-tree) ) }; __"
    fixup = "!sh -c '(git diff-files --quiet || (echo Unstaged changes, please commit or stash with --keep-index; exit 1)) && COMMIT=$(git rev-parse $1) && git commit --fixup=$COMMIT && git rebase -i --autosquash $COMMIT~1' -"
[giggle]
	main-window-maximized = true
	main-window-geometry = 700x550+1+61
	history-view-vpane-position = 362
	file-view-vpane-position = 578
	main-window-view = HistoryView
[push]
	default = tracking
[sendemail]
	smtpserver = /usr/bin/msmtp
	confirm = auto
[commit]
    gpgsign = true
[gitreview]
	username = ralphbean
	email = ralph.bean@gmail.com
	remote = origin
[core]
    editor = vim
    #hooksPath = /home/threebean/.git/hooks
[init]
	defaultBranch = main
	# templateDir = /home/threebean/.git-template
[rh-pre-commit]
	checkSecrets = true
	enableLocalConfig = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = true
